{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "CloudIQListBucket",
      "Effect": "Allow",
      "Action": [
        "s3:ListBucket",
        "s3:GetBucketLocation"
      ],
      "Resource": "arn:aws:s3:::marketplace-lakehouse-demo-9623"
    },
    {
      "Sid": "CloudIQReadWriteObjects",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject"
      ],
      "Resource": "arn:aws:s3:::marketplace-lakehouse-demo-9623/*"
    }
  ]
}
