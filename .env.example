# Minimum for local run: none required. All Azure values optional.
#
# Copy this file to .env and fill in only the values you need.
# Local PySpark + Delta runs require none of the Azure/Databricks values.

# Azure Storage (optional - cloud only)
AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_KEY=
AZURE_STORAGE_CONNECTION_STRING=

# Databricks (optional - cloud only)
DATABRICKS_HOST=
DATABRICKS_TOKEN=
DATABRICKS_CLUSTER_ID=

# Azure Data Factory (optional - cloud only)
ADF_FACTORY_NAME=

# MLflow tracking URI (optional - defaults to local file store 'mlruns')
MLFLOW_TRACKING_URI=
