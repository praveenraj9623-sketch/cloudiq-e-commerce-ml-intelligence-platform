# Minimum for local run: none required. Azure and AWS values are optional.
#
# Copy this file to .env and fill in only the values you need.
# Real secrets belong only in your local .env file or shell environment.
# .env must remain ignored by Git and must never be committed.
# Local PySpark + Delta runs require none of the Azure/Databricks/AWS values.

# Azure Storage (optional - cloud only)
AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_KEY=
AZURE_STORAGE_CONNECTION_STRING=

# Databricks (optional - cloud only)
DATABRICKS_HOST=
DATABRICKS_TOKEN=
DATABRICKS_CLUSTER_ID=

# Azure Data Factory (optional - cloud only)
ADF_FACTORY_NAME=

# AWS S3 (optional - separate read-only storage verification demo)
AWS_S3_BUCKET=
AWS_DEFAULT_REGION=ap-south-1
AWS_S3_PREFIX=raw/olist/
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# MLflow tracking URI (optional - defaults to local file store 'mlruns')
MLFLOW_TRACKING_URI=
